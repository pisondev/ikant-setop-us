    "name": "Ikan't Setop Us API",
    "description": "Postman collection for the Ikan't Setop Us MVP API. Import with the local environment and run master data requests before stock and stock-out requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/health"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Fish Types",
      "item": [
        {
          "name": "List Fish Types",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/fish-types"
          },
          "response": []
        },
        {
          "name": "Create Fish Type",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.id) {",
                  "  pm.environment.set('fish_type_id', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tuna\",\n  \"image_url\": \"/images/fish/tuna.png\",\n  \"description\": \"Ikan tuna\"\n}"
            },
            "url": "{{base_url}}/fish-types"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Cold Storages",
      "item": [
        {
