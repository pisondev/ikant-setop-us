    {
      "name": "Stocks",
      "item": [
        {
          "name": "Create Stock Batch",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.id) {",
                  "  pm.environment.set('stock_batch_id', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fish_type_id\": \"{{fish_type_id}}\",\n  \"cold_storage_id\": \"{{cold_storage_id}}\",\n  \"quality\": \"baik\",\n  \"initial_weight_kg\": 50,\n  \"entered_at\": \"{{$isoTimestamp}}\",\n  \"notes\": \"Tangkapan pagi\"\n}"
            },
            "url": "{{base_url}}/stocks"
          },
          "response": []
        },
        {
          "name": "List Stocks",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/stocks?sort=fifo"
          },
          "response": []
        },
        {
          "name": "List Stocks by Filters",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/stocks?fish_type_id={{fish_type_id}}&quality={{quality}}&cold_storage_id={{cold_storage_id}}&status={{stock_status}}&sort=fifo"
          },
          "response": []
        },
        {
          "name": "List FIFO Stocks",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/stocks/fifo"
          },
          "response": []
        },
        {
          "name": "List FIFO Stocks by Fish Type",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/stocks/fifo?fish_type_id={{fish_type_id}}"
          },
          "response": []
        },
        {
          "name": "List FIFO Stocks Paginated",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/stocks/fifo?fish_type_id={{fish_type_id}}&limit={{limit}}&offset={{offset}}"
          },
          "response": []
        },
        {
          "name": "Get Stock Detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/stocks/{{stock_batch_id}}"
          },
          "response": []
        },
        {
          "name": "Update Stock Quality",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quality\": \"sedang\",\n  \"notes\": \"Kualitas mata ikan mulai menurun\"\n}"
            },
            "url": "{{base_url}}/stocks/{{stock_batch_id}}/quality"
          },
          "response": []
        },
        {
          "name": "Update Stock Location",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cold_storage_id\": \"{{cold_storage_id}}\",\n  \"notes\": \"Dipindahkan ke cold storage pilihan\"\n}"
            },
            "url": "{{base_url}}/stocks/{{stock_batch_id}}/location"
          },
          "response": []
        }
      ]
